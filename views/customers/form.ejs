<%- include('../partials/header') %>

<div class="page-header">
  <h1><%= customer ? 'Edit Customer' : 'Add Customer' %></h1>
  <a href="/customers" class="btn btn-outline">← Back</a>
</div>

<div class="card form-card">
  <form method="POST" action="<%= customer ? '/customers/' + customer.id + '?_method=PUT' : '/customers' %>">
    <div class="form-grid">
      <div class="form-group">
        <label>Name *</label>
        <input type="text" name="name" class="input" required value="<%= customer ? customer.name : '' %>">
      </div>
      <div class="form-group">
        <label>Phone</label>
        <input type="text" name="phone" class="input" value="<%= customer ? customer.phone || '' : '' %>">
      </div>
      <div class="form-group">
        <label>Email</label>
        <input type="email" name="email" class="input" value="<%= customer ? customer.email || '' : '' %>">
      </div>
    </div>
    <div class="form-group">
      <label>Address</label>
      <textarea name="address" class="input" rows="3"><%= customer ? customer.address || '' : '' %></textarea>
    </div>
    <div class="form-actions">
      <button type="submit" class="btn btn-primary"><%= customer ? 'Update' : 'Add Customer' %></button>
      <a href="/customers" class="btn btn-outline">Cancel</a>
    </div>
  </form>
</div>

<%- include('../partials/footer') %>
