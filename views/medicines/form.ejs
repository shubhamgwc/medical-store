<%- include('../partials/header') %>

<div class="page-header">
  <h1><%= medicine ? 'Edit Medicine' : 'Add New Medicine' %></h1>
  <a href="/medicines" class="btn btn-outline">← Back</a>
</div>

<div class="card form-card">
  <form method="POST" action="<%= medicine ? '/medicines/' + medicine.id + '?_method=PUT' : '/medicines' %>">
    <div class="form-grid">
      <div class="form-group">
        <label>Medicine Name *</label>
        <input type="text" name="name" class="input" required value="<%= medicine ? medicine.name : '' %>" placeholder="e.g. Paracetamol 500mg">
      </div>
      <div class="form-group">
        <label>Generic Name</label>
        <input type="text" name="generic_name" class="input" value="<%= medicine ? medicine.generic_name || '' : '' %>" placeholder="e.g. Paracetamol">
      </div>
      <div class="form-group">
        <label>Manufacturer</label>
        <input type="text" name="manufacturer" class="input" value="<%= medicine ? medicine.manufacturer || '' : '' %>">
      </div>
      <div class="form-group">
        <label>Category</label>
        <input type="text" name="category" class="input" value="<%= medicine ? medicine.category || '' : '' %>" placeholder="e.g. Antibiotics, Pain Relief">
      </div>
      <div class="form-group">
        <label>Unit</label>
        <select name="unit" class="input">
          <% ['strip', 'bottle', 'tablet', 'capsule', 'injection', 'syrup', 'cream', 'drops', 'sachet', 'other'].forEach(u => { %>
            <option value="<%= u %>" <%= (medicine && medicine.unit === u) ? 'selected' : '' %>><%= u %></option>
          <% }) %>
        </select>
      </div>
      <div class="form-group">
        <label>Batch Number</label>
        <input type="text" name="batch_number" class="input" value="<%= medicine ? medicine.batch_number || '' : '' %>">
      </div>
      <div class="form-group">
        <label>Purchase Price (₹) *</label>
        <input type="number" name="purchase_price" step="0.01" class="input" required value="<%= medicine ? medicine.purchase_price : '' %>" placeholder="0.00">
      </div>
      <div class="form-group">
        <label>Selling Price (₹) *</label>
        <input type="number" name="selling_price" step="0.01" class="input" required value="<%= medicine ? medicine.selling_price : '' %>" placeholder="0.00">
      </div>
      <div class="form-group">
        <label>Stock Quantity</label>
        <input type="number" name="stock_quantity" class="input" value="<%= medicine ? medicine.stock_quantity : 0 %>" min="0">
      </div>
      <div class="form-group">
        <label>Low Stock Alert At</label>
        <input type="number" name="min_stock_alert" class="input" value="<%= medicine ? medicine.min_stock_alert : 10 %>" min="0">
      </div>
      <div class="form-group">
        <label>Expiry Date</label>
        <input type="date" name="expiry_date" class="input" value="<%= medicine && medicine.expiry_date ? new Date(medicine.expiry_date).toISOString().slice(0,10) : '' %>">
      </div>
    </div>
    <div class="form-group">
      <label>Description / Notes</label>
      <textarea name="description" class="input" rows="3" placeholder="Any notes about this medicine..."><%= medicine ? medicine.description || '' : '' %></textarea>
    </div>
    <div class="form-actions">
      <button type="submit" class="btn btn-primary"><%= medicine ? 'Update Medicine' : 'Add Medicine' %></button>
      <a href="/medicines" class="btn btn-outline">Cancel</a>
    </div>
  </form>
</div>

<%- include('../partials/footer') %>
