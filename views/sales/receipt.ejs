<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Receipt - <%= invoice.invoice_number %></title>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Mono:wght@400;500&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    @media print {
      .no-print { display: none !important; }
      body { background: white; }
      .receipt-wrapper { box-shadow: none; max-width: 100%; }
    }
    body { background: #f0f4f8; display: flex; flex-direction: column; align-items: center; padding: 20px; font-family: 'DM Sans', sans-serif; }
    .receipt-actions { margin-bottom: 20px; display: flex; gap: 10px; }
    .receipt-wrapper {
      background: white;
      width: 380px;
      padding: 30px;
      box-shadow: 0 4px 30px rgba(0,0,0,0.12);
      border-radius: 12px;
    }
    .receipt-header { text-align: center; border-bottom: 2px dashed #ddd; padding-bottom: 16px; margin-bottom: 16px; }
    .store-logo { font-family: 'Syne', sans-serif; font-size: 24px; font-weight: 800; color: #0a4b3a; }
    .store-sub { font-size: 12px; color: #666; margin-top: 2px; }
    .invoice-num { font-family: 'DM Mono', monospace; font-size: 11px; background: #f0fdf4; padding: 4px 10px; border-radius: 4px; display: inline-block; margin: 8px 0; color: #0a4b3a; }
    .receipt-info { display: flex; justify-content: space-between; font-size: 12px; margin-bottom: 16px; color: #555; }
    .items-table { width: 100%; border-collapse: collapse; font-size: 13px; margin-bottom: 16px; }
    .items-table th { text-align: left; padding: 6px 0; border-bottom: 1px solid #eee; color: #888; font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px; }
    .items-table td { padding: 7px 0; border-bottom: 1px solid #f5f5f5; }
    .items-table td:last-child { text-align: right; }
    .items-table th:last-child { text-align: right; }
    .totals { border-top: 2px dashed #ddd; padding-top: 12px; }
    .total-row { display: flex; justify-content: space-between; font-size: 13px; padding: 3px 0; color: #555; }
    .total-final { font-size: 18px; font-weight: 700; color: #0a4b3a; border-top: 1px solid #eee; margin-top: 8px; padding-top: 8px; }
    .receipt-footer { text-align: center; margin-top: 20px; font-size: 11px; color: #aaa; border-top: 1px dashed #eee; padding-top: 14px; }
    .payment-badge { display: inline-block; background: #f0fdf4; color: #0a4b3a; padding: 2px 8px; border-radius: 4px; font-size: 11px; text-transform: uppercase; font-weight: 600; }
  </style>
</head>
<body>

<div class="receipt-actions no-print">
  <button onclick="window.print()" class="btn btn-primary">🖨 Print Receipt</button>
  <a href="/sales/new" class="btn btn-primary">+ New Sale</a>
  <a href="/sales" class="btn btn-outline">← All Sales</a>
</div>

<div class="receipt-wrapper">
  <div class="receipt-header">
    <div class="store-logo">⚕ <%= store.name %></div>
    <div class="store-sub"><%= store.address || 'Your Trusted Medical Store' %></div>
    <div class="invoice-num"><%= invoice.invoice_number %></div>
  </div>

  <div class="receipt-info">
    <div>
      <strong>Customer:</strong><br>
      <%= invoice.customer_name || 'Walk-in Customer' %>
      <% if (invoice.customer_phone) { %><br><%= invoice.customer_phone %><% } %>
    </div>
    <div style="text-align:right">
      <strong>Date:</strong><br>
      <%= new Date(invoice.created_at).toLocaleDateString('en-IN') %><br>
      <%= new Date(invoice.created_at).toLocaleTimeString('en-IN', {hour:'2-digit', minute:'2-digit'}) %>
    </div>
  </div>

  <table class="items-table">
    <thead>
      <tr>
        <th>Item</th>
        <th style="text-align:center">Qty</th>
        <th style="text-align:right">Price</th>
        <th>Total</th>
      </tr>
    </thead>
    <tbody>
      <% items.forEach(item => { %>
      <tr>
        <td><%= item.medicine_name %></td>
        <td style="text-align:center"><%= item.quantity %></td>
        <td style="text-align:right">₹<%= parseFloat(item.unit_price).toFixed(2) %></td>
        <td>₹<%= parseFloat(item.subtotal).toFixed(2) %></td>
      </tr>
      <% }) %>
    </tbody>
  </table>

  <div class="totals">
    <div class="total-row"><span>Subtotal</span><span>₹<%= parseFloat(invoice.subtotal).toFixed(2) %></span></div>
    <% if (parseFloat(invoice.discount_amount) > 0) { %>
    <div class="total-row"><span>Discount (<%= invoice.discount_percent %>%)</span><span>-₹<%= parseFloat(invoice.discount_amount).toFixed(2) %></span></div>
    <% } %>
    <% if (parseFloat(invoice.tax_amount) > 0) { %>
    <div class="total-row"><span>Tax (<%= invoice.tax_percent %>%)</span><span>+₹<%= parseFloat(invoice.tax_amount).toFixed(2) %></span></div>
    <% } %>
    <div class="total-row total-final"><span>TOTAL</span><span>₹<%= parseFloat(invoice.total_amount).toFixed(2) %></span></div>
    <div class="total-row" style="margin-top:8px">
      <span>Payment</span>
      <span class="payment-badge"><%= invoice.payment_method.toUpperCase() %></span>
    </div>
  </div>

  <% if (invoice.notes) { %>
  <div style="font-size:12px; color:#888; margin-top:12px; padding: 8px; background:#f9f9f9; border-radius: 6px;">
    Note: <%= invoice.notes %>
  </div>
  <% } %>

  <div class="receipt-footer">
    <% if (store.phone) { %><p>📞 <%= store.phone %></p><% } %>
    <% if (store.email) { %><p>✉ <%= store.email %></p><% } %>
    <p style="margin-top:8px">Thank you for your purchase!</p>
    <p>Get well soon 🙏</p>
  </div>
</div>

</body>
</html>
