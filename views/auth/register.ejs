<%- include('../partials/header') %>

<div class="page-header">
  <h1>Create Account</h1>
  <a href="/auth/login" class="btn btn-outline">← Back to Login</a>
</div>

<div class="card form-card" style="max-width:650px;margin:0 auto;">
  <form method="POST" action="/auth/register">

    <% if (locals.error) { %>
      <div class="alert alert-danger"><%= error %></div>
    <% } %>

    <div class="form-grid">

      <div class="form-group">
        <label>First Name *</label>
        <input type="text" name="first_name" class="input" required>
      </div>

      <div class="form-group">
        <label>Last Name</label>
        <input type="text" name="last_name" class="input">
      </div>

      <div class="form-group">
        <label>Email *</label>
        <input type="email" name="email" class="input" required>
      </div>

      <div class="form-group">
        <label>Password *</label>
        <input type="password" name="password" class="input" required>
      </div>

      <div class="form-group">
        <label>Phone</label>
        <input type="text" name="phone" class="input">
      </div>

    </div>

    <div class="form-actions">
      <button type="submit" class="btn btn-primary">Register</button>
      <a href="/auth/login" class="btn btn-outline">Cancel</a>
    </div>

  </form>
</div>

<%- include('../partials/footer') %>